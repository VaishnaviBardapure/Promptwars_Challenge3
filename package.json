{
    "name": "promptwars-carbon-platform",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
        "server:dev": "nodemon --watch server --exec node server/index.js",
        "client:dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "start": "cross-env NODE_ENV=production node server/index.js"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "devDependencies": {
        "@types/react": "^18.3.5",
        "@types/react-dom": "^18.3.5",
        "@vitejs/plugin-react": "^4.3.1",
        "concurrently": "^8.2.0",
        "cross-env": "^7.0.3",
        "nodemon": "^3.0.1",
        "typescript": "^5.6.2",
        "vite": "^5.4.1"
    }
}